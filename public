]
}
};

let currentLang = "ku";
let currentScreen = "entry";
let currentRoom = { roomCode: null, topic: null, players: [], host: null, gameStarted: false, currentQuestionIndex: 0, scores: {}, answersTimestamps: {} };
let gameInterval = null;
let selectedTopic = null;
let activeQuestions = [];
let isHost = false;
let myPlayerName = "";
let chatMessages = [];

const entryDiv = document.getElementById("entryScreen");
const lobbyDiv = document.getElementById("lobbyScreen");
const gameDiv = document.getElementById("gameScreen");
const podiumDiv = document.getElementById("podiumScreen");
const langBtns = document.querySelectorAll(".lang-btn");

function updateUITexts() { renderCurrentScreen(); }
function setScreen(screen) {
currentScreen = screen;
entryDiv.classList.add("hidden");
lobbyDiv.classList.add("hidden");
gameDiv.classList.add("hidden");
podiumDiv.classList.add("hidden");
if(screen === "entry") entryDiv.classList.remove("hidden");
if(screen === "lobby") lobbyDiv.classList.remove("hidden");
if(screen === "game") gameDiv.classList.remove("hidden");
if(screen === "podium") podiumDiv.classList.remove("hidden");
renderCurrentScreen();
}

function renderCurrentScreen() {
if(currentScreen === "entry") renderEntry();
if(currentScreen === "lobby") renderLobby();
if(currentScreen === "game") renderGame();
if(currentScreen === "podium") renderPodium();
}

function renderEntry() {}
function renderLobby() {
const lobbyDivContent = document.getElementById("lobbyDynamic");
if(!lobbyDivContent) return;
const topicOptions = currentLang === "ku" ? ["سەیارەکان", "زانست", "جوگرافیا", "زمانی هۆڵەندی"] : ["Auto's", "Wetenschap", "Geografie", "Nederlandse Taal"];
let html = `<div class="hero-card"><h2>${currentLang === "ku" ? "لۆبی ژوور" : "Lobby"}: ${currentRoom.roomCode}</h2>
<div class="room-code">${currentRoom.roomCode}</div>
<div><strong>${currentLang === "ku" ? "بابەت هەڵبژێرە" : "Kies onderwerp"}</strong></div>
<div style="display:flex; flex-wrap:wrap; gap:1rem; justify-content:center; margin:1rem 0;">`;
topicOptions.forEach(t => {
html += `<button class="btn topic-select" data-topic="${t}">${t}</button>`;
});
html += `</div><div class="players-panel"><h3>👥 ${currentLang === "ku" ? "یاریزانان" : "Spelers"}</h3><div id="playersList">${currentRoom.players.map(p => `<div class="player-card">${p} ${p === currentRoom.host ? "👑" : ""}</div>`).join("")}</div>`;
html += `<div class="chat-panel" style="margin-top:1rem;"><input type="text" id="chatInput" placeholder="${currentLang === "ku" ? "پەیام..." : "Bericht..."}" style="width:100%; padding:0.5rem;"><button id="sendChatBtn">📨</button><div id="chatMsgs" style="height:100px; overflow:auto;"></div></div>`;
if(isHost && !currentRoom.gameStarted) html += `<button id="startGameBtn" class="btn btn-primary" style="margin-top:1rem;">🚀 ${currentLang === "ku" ? "دەستپێکردنی یاری" : "Start spel"}</button>`;
html += `</div>`;
lobbyDivContent.innerHTML = html;
document.querySelectorAll(".topic-select").forEach(btn => {
btn.onclick = () => { if(isHost) { selectedTopic = btn.dataset.topic; currentRoom.topic = selectedTopic; renderLobby(); } };
});
if(isHost) document.getElementById("startGameBtn")?.addEventListener("click", startGame);
document.getElementById("sendChatBtn")?.addEventListener("click", () => { let inp = document.getElementById("chatInput"); if(inp.value) chatMessages.push(`${myPlayerName}: ${inp.value}`); renderLobby(); });
}

function startGame() {
if(!currentRoom.topic) { alert(currentLang === "ku" ? "تکایە بابەتێک هەڵبژێرە!" : "Kies een onderwerp!"); return; }
const topicKey = currentLang === "ku" ? currentRoom.topic : (currentRoom.topic === "Auto's" ? "سەیارەکان" : (currentRoom.topic === "Wetenschap" ? "زانست" : (currentRoom.topic === "Geografie" ? "جوگرافیا" : "زمانی هۆڵەندی")));
const qSet = QUESTIONS_DB[currentLang][topicKey] || QUESTIONS_DB["ku"]["سەیارەکان"];
activeQuestions = qSet.map((q,i) => ({ ...q }));
currentRoom.gameStarted = true;
currentRoom.currentQuestionIndex = 0;
currentRoom.scores = {};
currentRoom.players.forEach(p => currentRoom.scores[p] = 0);
setScreen("game");
}

function renderGame() {
if(!activeQuestions.length || currentRoom.currentQuestionIndex >= activeQuestions.length) { endGame(); return; }
const q = activeQuestions[currentRoom.currentQuestionIndex];
const container = document.getElementById("gameContainer");
if(!container) return;
let html = `<div class="scoreboard"><h3>🏆 ${currentLang === "ku" ? "خاڵەکان" : "Scores"}</h3>`;
for(let p of currentRoom.players) html += `<div>${p}: ${currentRoom.scores[p] || 0}</div>`;
html += `</div><div class="question-text">${q.text}</div><div class="answers-grid" id="answersGrid">`;
q.options.forEach((opt, idx) => {
html += `<div class="answer-btn" data-opt-index="${idx}">${String.fromCharCode(65+idx)}. ${opt}</div>`;
});
html += `</div><div id="timerMsg" style="text-align:center; margin-top:1rem;">⏱️ ${currentLang === "ku" ? "کات" : "Tijd"} 15s</div>`;
container.innerHTML = html;
let answered = false;
const timeLimit = 15;
let timeLeft = timeLimit;
const timerEl = document.getElementById("timerMsg");
const timerInterval = setInterval(() => {
if(!timerEl) return clearInterval(timerInterval);
timeLeft--;
timerEl.innerText = `⏱️ ${timeLeft}s`;
if(timeLeft <= 0 && !answered) {
clearInterval(timerInterval);
nextQuestion();
}
}, 1000);
document.querySelectorAll(".answer-btn").forEach(btn => {
btn.onclick = (e) => {
if(answered) return;
answered = true;
clearInterval(timerInterval);
const selected = parseInt(btn.dataset.optIndex);
const isCorrect = (selected === q.correct);
if(isCorrect) {
let points = Math.max(1, Math.floor(timeLeft/2)+5);
currentRoom.scores[myPlayerName] = (currentRoom.scores[myPlayerName] || 0) + points;
btn.classList.add("correct-highlight");
} else {
btn.classList.add("wrong-highlight");
document.querySelectorAll(".answer-btn")[q.correct]?.classList.add("correct-highlight");
}
setTimeout(() => { nextQuestion(); }, 1200);
};
});
window.nextQuestion = () => {
currentRoom.currentQuestionIndex++;
renderGame();
};
}

function endGame() {
const sorted = Object.entries(currentRoom.scores).sort((a,b)=>b[1]-a[1]);
const podiumData = sorted.slice(0,3);
currentRoom.gameStarted = false;
renderPodiumFinal(podiumData);
setScreen("podium");
}

function renderPodiumFinal(scoresArr) {
const podiumDivInner = document.getElementById("podiumContainer");
podiumDivInner.innerHTML = `<h2>🏅 ${currentLang === "ku" ? "پۆدیۆمی ڕێزلێنان" : "Erepodium"} 🏅</h2><div class="podium">
${scoresArr[0] ? `<div class="podium-item first">🥇 ${scoresArr[0][0]}<br>${scoresArr[0][1]} pts</div>` : ""}
${scoresArr[1] ? `<div class="podium-item second">🥈 ${scoresArr[1][0]}<br>${scoresArr[1][1]} pts</div>` : ""}
${scoresArr[2] ? `<div class="podium-item third">🥉 ${scoresArr[2][0]}<br>${scoresArr[2][1]} pts</div>` : ""}
</div>`;
}

