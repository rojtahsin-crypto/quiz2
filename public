};
document.getElementById("submitJoinBtn").onclick = () => {
let code = document.getElementById("roomCodeInput").value.trim().toUpperCase();
myPlayerName = document.getElementById("playerNameInput").value.trim();
if(!myPlayerName || !code) return;
currentRoom = { roomCode: code, topic: "سەیارەکان", players: [currentRoom?.players?.[0] || "Gast1", myPlayerName], host: currentRoom?.host || "Gast1", gameStarted: false, scores: {}, currentQuestionIndex:0 };
isHost = false;
setScreen("lobby");
renderLobby();
};
document.getElementById("backToLobbyBtn")?.addEventListener("click", () => { setScreen("lobby"); renderLobby(); });
langBtns.forEach(btn => {
btn.onclick = () => {
langBtns.forEach(b=>b.classList.remove("active"));
btn.classList.add("active");
currentLang = btn.dataset.lang;
updateUITexts();
};
});
renderEntry();
setScreen("entry");

