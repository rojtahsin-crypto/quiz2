        }
    });
};

// Topic select via socket
window.selectTopicViaSocket = (topicKey) => {
    if(isHost) {
        socket.emit('selectTopic', { roomCode: currentRoom.roomCode, topicKey });
    }
};

// Vervang topic select knoppen in lobby
function renderLobbyWithSocket() {
    const lobbyDivContent = document.getElementById("lobbyDynamic");
    if(!lobbyDivContent) return;
    const topicOptions = currentLang === "ku" ? ["سەیارەکان", "زانست", "جوگرافیا", "زمانی هۆڵەندی"] : ["Auto's", "Wetenschap", "Geografie", "Nederlandse Taal"];
    let html = `<div class="hero-card"><h2>${currentLang === "ku" ? "لۆبی ژوور" : "Lobby"}: ${currentRoom.roomCode}</h2>
    <div class="room-code">${currentRoom.roomCode}</div>
    <div><strong>${currentLang === "ku" ? "بابەت هەڵبژێرە" : "Kies onderwerp"}</strong></div>
    <div style="display:flex; flex-wrap:wrap; gap:1rem; justify-content:center; margin:1rem 0;">`;
    topicOptions.forEach(t => {
        html += `<button class="btn topic-select-socket" data-topic="${t}">${t}</button>`;
    });
    html += `</div><div class="players-panel"><h3>👥 ${currentLang === "ku" ? "یاریزانان" : "Spelers"}</h3><div id="playersList">${currentRoom.players.map(p => `<div class="player-card">${p} ${p === currentRoom.host ? "👑" : ""}</div>`).join("")}</div>`;
    html += `<div class="chat-panel" style="margin-top:1rem;"><input type="text" id="chatInput" placeholder="${currentLang === "ku" ? "پەیام..." : "Bericht..."}" style="width:100%; padding:0.5rem;"><button id="sendChatBtnSocket">📨</button><div id="chatMsgs" style="height:100px; overflow:auto;"></div></div>`;
    if(isHost && !currentRoom.gameStarted) html += `<button id="startGameBtnSocket" class="btn btn-primary" style="margin-top:1rem;">🚀 ${currentLang === "ku" ? "دەستپێکردنی یاری" : "Start spel"}</button>`;
    html += `</div>`;
    lobbyDivContent.innerHTML = html;
    
    document.querySelectorAll(".topic-select-socket").forEach(btn => {
        btn.onclick = () => { if(isHost) socket.emit('selectTopic', { roomCode: currentRoom.roomCode, topicKey: btn.dataset.topic }); };
    });
    if(isHost) document.getElementById("startGameBtnSocket")?.addEventListener("click", () => {
        socket.emit('startGame', { roomCode: currentRoom.roomCode });
    });
    document.getElementById("sendChatBtnSocket")?.addEventListener("click", () => {
        let inp = document.getElementById("chatInput");
        if(inp.value) {
            socket.emit('chatMessage', { roomCode: currentRoom.roomCode, message: inp.value });
            inp.value = '';
        }
    });
}

// Overschrijf renderLobby met de socket versie
const originalRenderLobby = renderLobby;
renderLobby = renderLobbyWithSocket;

// Socket events van server
socket.on('roomUpdate', (data) => {
    currentRoom.players = data.players;
    currentRoom.host = data.host;
    currentRoom.gameStarted = data.gameStarted;
    if(currentScreen === 'lobby') renderLobby();
});

socket.on('topicSelected', (data) => {
    currentRoom.topic = data.topic;
    if(currentScreen === 'lobby') renderLobby();
});

socket.on('gameStarting', () => {
    currentRoom.gameStarted = true;
    currentRoom.currentQuestionIndex = 0;
    currentRoom.scores = {};
    currentRoom.players.forEach(p => currentRoom.scores[p] = 0);
    setScreen('game');
});

socket.on('newQuestion', (q) => {
    currentRoom.currentQuestionIndex = q.index;
    // Sla de vraag op in activeQuestions
    activeQuestions[q.index] = { text: q.text, options: q.options, correct: null };
    if(currentScreen === 'game') {
        renderGameFromSocket(q);
    }
});

function renderGameFromSocket(q) {
    const container = document.getElementById("gameContainer");
    if(!container) return;
    let html = `<div class="scoreboard"><h3>🏆 ${currentLang === "ku" ? "خاڵەکان" : "Scores"}</h3>`;
    for(let p of currentRoom.players) html += `<div>${p}: ${currentRoom.scores[p] || 0}</div>`;
    html += `</div><div class="question-text">${q.text}</div><div class="answers-grid" id="answersGrid">`;
    q.options.forEach((opt, idx) => {
        html += `<div class="answer-btn" data-opt-index="${idx}">${String.fromCharCode(65+idx)}. ${opt}</div>`;
    });
    html += `</div><div id="timerMsg" style="text-align:center; margin-top:1rem;">⏱️ ${currentLang === "ku" ? "کات" : "Tijd"} 15s</div>`;
    container.innerHTML = html;
    
    let answered = false;
    let timeLeft = 15;
    const timerEl = document.getElementById("timerMsg");
    const interval = setInterval(() => {
        timeLeft--;
        if(timerEl) timerEl.innerText = `⏱️ ${timeLeft}s`;
        if(timeLeft <= 0 && !answered) {
            clearInterval(interval);
        }
    }, 1000);
    
    document.querySelectorAll(".answer-btn").forEach(btn => {
        btn.onclick = () => {
            if(answered) return;
            answered = true;
            clearInterval(interval);
            const selected = parseInt(btn.dataset.optIndex);
            const timeSpent = (15 - timeLeft) * 1000;
            socket.emit('submitAnswer', { roomCode: currentRoom.roomCode, answerIndex: selected, timeSpent }, (res) => {
                if(res && res.success) {
                    if(res.isCorrect) btn.classList.add("correct-highlight");
                    else {
                        btn.classList.add("wrong-highlight");
                        // Toon het juiste antwoord (indien bekend)
                    }
                }
            });
        };
    });
}

socket.on('scoreUpdate', (data) => {
    currentRoom.scores = data.scores;
    if(currentScreen === 'game') {
        // Update scores in game scherm
        const scoreDiv = document.querySelector("#gameContainer .scoreboard");
        if(scoreDiv) {
            let html = `<h3>🏆 ${currentLang === "ku" ? "خاڵەکان" : "Scores"}</h3>`;
            for(let p of currentRoom.players) html += `<div>${p}: ${currentRoom.scores[p] || 0}</div>`;
            scoreDiv.innerHTML = html;
        }
    }
});

socket.on('gameEnd', (data) => {
    const podiumArr = data.podium.map(p => [p.name, p.score]);
    renderPodiumFinal(podiumArr);
    setScreen('podium');
});

socket.on('chatMessage', (msg) => {
    chatMessages.push(msg);
    if(currentScreen === 'lobby') renderLobby();
});
</script>
