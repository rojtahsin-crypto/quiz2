        }
    });
};

// Join kamer via socket
document.getElementById("submitJoinBtn").onclick = () => {
    let code = document.getElementById("roomCodeInput").value.trim().toUpperCase();
    myPlayerName = document.getElementById("playerNameInput").value.trim();
    if(!myPlayerName || !code) return;
    socket.emit('joinRoom', { roomCode: code, playerName: myPlayerName }, (response) => {
        if(response.success) {
            currentRoom.roomCode = code;
